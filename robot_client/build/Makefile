.PHONY : src/weighted_ik.cpp.o

src/weighted_ik.i: src/weighted_ik.cpp.i
.PHONY : src/weighted_ik.i

# target to preprocess a source file
src/weighted_ik.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/weighted_ik.dir/build.make CMakeFiles/weighted_ik.dir/src/weighted_ik.cpp.i
.PHONY : src/weighted_ik.cpp.i

src/weighted_ik.s: src/weighted_ik.cpp.s
.PHONY : src/weighted_ik.s

# target to generate assembly for a file
src/weighted_ik.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/weighted_ik.dir/build.make CMakeFiles/weighted_ik.dir/src/weighted_ik.cpp.s
.PHONY : src/weighted_ik.cpp.s

